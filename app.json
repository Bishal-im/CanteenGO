{
  "expo": {
    "name": "CanteenGo",
    "slug": "canteengo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "canteengo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.newa060.canteengo"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
